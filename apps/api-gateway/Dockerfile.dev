FROM python:3.14-slim
RUN apt-get update && apt-get install -y nodejs npm curl && npm install -g pnpm && pnpm config set ignore-workspace-root-check true && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY packages/shared /app/packages/shared
COPY packages/ai-engine /app/packages/ai-engine
COPY apps/api-gateway /app/apps/api-gateway

RUN pip install --upgrade pip && \
    pip install --upgrade -e /app/packages/shared -e /app/packages/ai-engine -e /app/apps/api-gateway

# Pre-download FastEmbed model to avoid startup delay
RUN python -c "from fastembed import TextEmbedding; TextEmbedding(model_name='sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2')"

CMD ["sh", "-c", "cd apps/api-gateway && uvicorn src.main:app --host 0.0.0.0 --port 8000 --reload"]
