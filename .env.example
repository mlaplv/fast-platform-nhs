# ==============================================================================
# FAST-PLATFORM-CORE: V61.1 SSOT (SINGLE SOURCE OF TRUTH)
# MISSION: OPERATION IRON HAND (LOCKDOWN MODE)
# ==============================================================================

# --- [ SECURITY & DOMAINS ] ---
# Rules: R31, R32 (Zero-Trust Lockdown)
APP_DOMAIN=smartshop.test
API_DOMAIN=api.smartshop.test
ADMIN_DOMAIN=admin.smartshop.test
ALLOWED_HOSTS=smartshop.test,api.smartshop.test,admin.smartshop.test,localhost,127.0.0.1

# --- [ DATABASE ] ---
# Postgres (PROD) or SQLite (DEV/TEST)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fast_platform

# --- [ AI CORE: TRINITY BRIDGE ] ---
# Multi-key rotation (comma-separated for Free Tier scalability)
GEMINI_API_KEY=your_key_1,your_key_2
TIER2_MODEL=gemini-2.0-flash

# --- [ AI SUPERVISOR PROTOCOL ] ---
# Machine-to-Machine Secret (Zero-DB Auth)
X_AGENT_KEY=change_me_to_a_secure_uuid

# --- [ INFRASTRUCTURE & LIMITS ] ---
# Hardened for 2GB RAM VPS
MAX_MEDIAPROCESS_WORKERS=3
HTTP_TIMEOUT_SECONDS=30.0
ORCHESTRATOR_SEMAPHORE_LIMIT=3

# --- [ EXTERNAL SERVICES ] ---
# Google Custom Search (For AssetHunter)
GOOGLE_SEARCH_CX=33041eeeedfcb4722
GOOGLE_SEARCH_KEYS=key1,key2

# --- [ CACHE (VIRAL LAYER) ] ---
REDIS_URL=redis://localhost:6379/0
CONTENT_CACHE_TTL=60
