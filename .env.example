# Fast Platform Environment Variables
# ⚠️  SECURITY WARNING: Never commit .env file to version control!
# Generated from .env.info template

# ==========================================
# DOMAIN & PATH CONFIGURATION (SSOT)
# ==========================================
APP_DOMAIN=smartshop.test
API_DOMAIN=api.smartshop.test
ADMIN_DOMAIN=admin.smartshop.test

# Dynamic URL Construction
APP_URL=https://${APP_DOMAIN}
API_URL=https://${API_DOMAIN}
ADMIN_URL=https://${ADMIN_DOMAIN}


# ==========================================
# SECURITY SETTINGS (REQUIRED)
# ==========================================
SECRET_KEY=6e2cb5f398a7844d00c9bd047349281f150616640e2284f6c941b68070b0a75c
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Internal API token for service-to-service communication (R25: no hardcoded secrets)
INTERNAL_API_TOKEN=fast-platform-internal-secret-2024

# ==========================================
# GIAI ĐOẠN 3: RATE LIMITING & SECURITY CONFIG
# ==========================================
# Số lượng Request tối đa cho API thường trên 1 phút
RATE_LIMIT_GLOBAL_MINUTE=100
# Số lượng Request tối đa cho API Login trên 1 phút (Chống Spam/Brute-force)
RATE_LIMIT_AUTH_MINUTE=5

# ==========================================
# M2M: QUẢN TRỊ NGÂN SÁCH A2A TỐI THƯỢNG (TIÊN QUYẾT)
# ==========================================
# Ngân sách LLM tối đa mỗi ngày (USD). Vượt là Circuit Breaker ĐÓNG BĂNG MỌI LLM.
DAILY_LLM_BUDGET_USD=5.00
# Giới hạn số lượng Token tuyệt đối cho 1 Session (Tránh thất thoát nếu đàm phán kéo dài)
MAX_SESSION_TOKENS=16000
# Số lượng vòng đàm phán tối đa giữa các Agent (Chống A2A Deadlock/DoW)
MAX_A2A_TURNS=5

# Bật/Tắt kiểm duyệt Semantic Poisoning & Prompt Injection nâng cao (The Semantic Shield)
ENABLE_A2A_FIREWALL=true

# CORS Origins (comma-separated, no wildcards in production)
BACKEND_CORS_ORIGINS=http://${APP_DOMAIN},https://${APP_DOMAIN},http://${ADMIN_DOMAIN},https://${ADMIN_DOMAIN},http://${API_DOMAIN},https://${API_DOMAIN},http://${ADMIN_DOMAIN}:5173

# Allowed Hosts (comma-separated, no wildcards in production)
ALLOWED_HOSTS=${APP_DOMAIN},${ADMIN_DOMAIN},${API_DOMAIN},backend,api-gateway

