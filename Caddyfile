{$APP_DOMAIN}, {$ADMIN_DOMAIN} {
    # Local/Internal TLS for .test domains
    tls internal

    # Matched to exclude SSE and large binary streams from compression (R90: Protocol Stability)
    @encodable {
        not header Content-Type text/event-stream
        not path /api/v1/*/stream*
        not path /ws/*
    }
    encode @encodable zstd gzip

    handle /api/v1/*/stream* {
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    handle /api/v1/content/campaigns/*/stream {
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    handle /api/* {
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    handle /ws/* {
        reverse_proxy api:8000 {
            flush_interval -1
        }
    }

    # Frontend Dev/Stage Proxy (Docker Synergy)
    handle /* {
        reverse_proxy ui:5173
    }

    # Logs with Rotation (R90: Limit log bloat)
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
            roll_keep_for 720h
        }
    }
}

{$API_DOMAIN} {
    tls internal
    reverse_proxy api:8000 {
        flush_interval -1
    }
}
