(service_proxy) {
	reverse_proxy api:8000 {
		flush_interval -1
		header_up X-Real-IP {remote_host}
	}
}

(security_headers) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(self), geolocation=(), interest-cohort=(), attribution-reporting=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Content-Security-Policy "default-src 'self'; media-src 'self' data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://www.googletagmanager.com https://*.googletagmanager.com https://connect.facebook.net https://*.facebook.net https://*.doubleclick.net https://*.googleadservices.com https://*.googlesyndication.com https://*.google.com https://*.google.com.vn https://*.google.vn https://*.osmo.vn https://osmo.vn; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://api.qrserver.com https://www.googletagmanager.com https://*.googletagmanager.com https://*.google-analytics.com https://*.doubleclick.net https://*.facebook.com https://*.osmo.vn https://osmo.vn https://*.google.com https://*.google.com.vn https://*.google.vn https://*.googleadservices.com https://*.googlesyndication.com; connect-src 'self' https://unpkg.com https://www.googletagmanager.com https://*.googletagmanager.com https://*.google-analytics.com https://*.analytics.google.com https://*.doubleclick.net https://*.g.doubleclick.net https://*.facebook.com https://*.google.com https://*.google.com.vn https://*.google.vn https://*.googleadservices.com https://*.googlesyndication.com https://*.osmo.vn https://osmo.vn; font-src 'self' https://fonts.gstatic.com; frame-src 'self' https://*.doubleclick.net https://*.facebook.com https://*.google.com https://*.google.com.vn https://*.google.vn; object-src 'none';"
		-Server
	}
}

# Explicit HTTP Block to prevent ACME redirect loops and boost TLS bootstrapping
http://{$APP_DOMAIN}, http://{$ADMIN_DOMAIN}, http://{$API_DOMAIN} {
	# Let Caddy's internal ACME solver handle HTTP challenge on port 80 directly
	@acme path /.well-known/acme-challenge/*
	handle @acme {
		# Fallback to bypass redirection
	}

	# Redirect all other HTTP traffic to HTTPS
	handle {
		redir https://{host}{uri} permanent
	}
}

https://{$APP_DOMAIN}, https://{$ADMIN_DOMAIN}, https://{$API_DOMAIN} {
	# tls internal  # removed to allow ACME automatic certificates
	import security_headers


	# Serve dynamic thumbnail cache with fallback handler (Elite V3.1)
	@cached_thumbnail path_regexp thumb ^/v65_assets/cache/t_(\d+)_75_([a-fA-F0-9\-]{36})
	route @cached_thumbnail {
		root * /app/frontend/static
		@no_thumbnail not file {path}
		rewrite @no_thumbnail /api/v1/media/{re.thumb.2}/thumb?w={re.thumb.1}
		reverse_proxy @no_thumbnail api:8000 {
			flush_interval -1
			header_up X-Real-IP {remote_host}
		}
		header Cache-Control "public, max-age=31536000"
		file_server
	}

	# Serve dynamic/static assets directly from static folder for all domains (Elite V2.2)
	@dynamic_assets path /uploads/* /v65_assets/* /avatars/* /client_uploads/*
	handle @dynamic_assets {
		root * /app/frontend/static
		header Cache-Control "public, max-age=31536000"
		file_server
	}

	# Serve storefront static files directly with long-lived Cache-Control headers (Elite V3.0)
	@static_files {
		path *.webp *.png *.jpg *.jpeg *.svg *.gif *.ico *.js *.css *.woff2 *.ttf
		not {
			path /_app/* /wasm/* /vad/* /models/*
		}
	}
	handle @static_files {
		root * /app/frontend/static
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}


	# Compression logic (Exclude SSE, WS, and streaming endpoints)
	@encodable {
		not header Content-Type text/event-stream
		not path /api/v1/*/stream*
		not path /ws/*
	}

	encode @encodable zstd gzip

	# Backend Routes (Unified)
	handle /api/* {
		import service_proxy
	}

	# WASM & AI Core Static Assets CORS policy (Elite V3.0)
	@wasm_assets path /wasm/* /vad/* /models/*
	handle @wasm_assets {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, POST, OPTIONS"
		header Access-Control-Allow-Headers "*"
		import service_proxy
	}

	@robots_txt {
		host {$APP_DOMAIN} {$ADMIN_DOMAIN}
		path /robots.txt
	}
	handle @robots_txt {
		root * /app/frontend/static
		file_server
	}

	handle /sitemap.xml {
		import service_proxy
	}

	handle /google-merchant.xml* {
		import service_proxy
	}

	handle /ws/* {
		import service_proxy
	}

	# Frontend Routing (Only for main and admin domains) - SSR Reverse Proxy
	@frontend_host host {$APP_DOMAIN} {$ADMIN_DOMAIN}
	handle @frontend_host {
		reverse_proxy ui:3000
	}

	# Fallback for API_DOMAIN (proxy everything to backend if not caught by /api/*)
	@api_host host {$API_DOMAIN}
	handle @api_host {
		import service_proxy
	}

	# Logs with Rotation (Elite V2.2: Hardened logging)
	log {
		output file /var/log/caddy/access.log {
			roll_size 10mb
			roll_keep 5
			roll_keep_for 720h
		}
	}
}
